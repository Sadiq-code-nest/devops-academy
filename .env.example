# ═══════════════════════════════════════════════════════════
#  DevOps Academy — Environment Variables Template
#  Copy to .env.dev or .env.prod and fill in real values.
#  NEVER commit .env files with real secrets to git.
# ═══════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
APP_PORT=8080
APP_VERSION=1.0.0
APP_NAME=devops-academy

# ── Docker ──────────────────────────────────────────────────
DOCKER_USER=mohdarif
DOCKER_IMAGE=devops-academy
DOCKER_TAG=latest

# ── Docker Hub (set in Jenkins credentials, not here) ───────
# DOCKERHUB_USERNAME=your-username
# DOCKERHUB_TOKEN=your-access-token

# ── AWS (if deploying to EC2) ───────────────────────────────
# AWS_REGION=ap-southeast-1
# AWS_ACCOUNT_ID=123456789012
# ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

# ── Notifications ────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# ALERT_EMAIL=devops@yourcompany.com

# ── Monitoring ───────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy
# DATADOG_API_KEY=your-datadog-api-key
